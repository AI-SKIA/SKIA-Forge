{
  "name": "skia-ide",
  "version": "1.0.0",
  "description": "SKIA FORGE — Desktop IDE",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron dist/main/main.js",
    "build": "tsc -p tsconfig.main.json && webpack --config webpack.config.js",
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"webpack --config webpack.config.js --watch\" \"wait-on dist/main/main.js && electron dist/main/main.js\"",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:all": "npm run build && electron-builder --win --mac --linux --publish never"
  },
  "build": {
    "appId": "ca.skia.forge",
    "productName": "SKIA FORGE",
    "icon": "assets/skia-forge-app",
    "copyright": "© 2026 SKIA Singularity Continuum",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/renderer/assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [ "x64" ]
        }
      ],
      "icon": "assets/skia-forge-app.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/skia-forge-app.ico",
      "uninstallerIcon": "assets/skia-forge-app.ico",
      "artifactName": "SKIA-FORGE-Setup-${version}-win-x64.exe",
      "shortcutName": "SKIA FORGE"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [ "x64" ]
        },
        {
          "target": "dmg",
          "arch": [ "arm64" ]
        }
      ],
      "icon": "assets/skia-forge-app.icns",
      "artifactName": "SKIA-FORGE-${version}-mac-${arch}.dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [ "x64" ]
        }
      ],
      "icon": "assets/skia-forge-app.png",
      "artifactName": "SKIA-FORGE-${version}-linux-x64.AppImage",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "AI-SKIA",
      "repo": "SKIA-Forge",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "monaco-editor": "^0.47.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}