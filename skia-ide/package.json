{
  "name": "skia-ide",
  "version": "0.1.0",
  "description": "SKIA IDE — Sovereign AI-Powered Development Environment",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron dist/main/main.js",
    "build": "tsc -p tsconfig.main.json && webpack --config webpack.config.js",
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"webpack --config webpack.config.js --watch\" \"wait-on dist/main/main.js && electron dist/main/main.js\""
  },
  "dependencies": {
    "electron": "^30.0.0",
    "monaco-editor": "^0.47.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.1",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}